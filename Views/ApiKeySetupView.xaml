<Window x:Class="BIBIM_MVP.ApiKeySetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIBIM — API Keys &amp; Models"
        Width="480" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E1E1E1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Pretendard, Malgun Gothic, Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="DescText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Pretendard, Malgun Gothic, Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Pretendard, Malgun Gothic, Segoe UI"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#707070"/>
                    <Setter Property="Background" Value="#252526"/>
                    <Setter Property="BorderBrush" Value="#333337"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Main title -->
            <RowDefinition Height="Auto"/>  <!-- 1: Claude section title -->
            <RowDefinition Height="Auto"/>  <!-- 2: Claude description -->
            <RowDefinition Height="Auto"/>  <!-- 3: Claude key box -->
            <RowDefinition Height="Auto"/>  <!-- 4: Claude model combo -->
            <RowDefinition Height="Auto"/>  <!-- 5: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 6: Gemini section title -->
            <RowDefinition Height="Auto"/>  <!-- 7: Gemini description -->
            <RowDefinition Height="Auto"/>  <!-- 8: Gemini key box -->
            <RowDefinition Height="Auto"/>  <!-- 9: Gemini model combo -->
            <RowDefinition Height="*"/>     <!-- 10: Error / spacer -->
            <RowDefinition Height="Auto"/>  <!-- 11: Buttons -->
        </Grid.RowDefinitions>

        <!-- Main title -->
        <TextBlock Grid.Row="0" Text="API Keys &amp; Models"
                   Foreground="#E1E1E1" FontSize="16" FontWeight="Bold"
                   FontFamily="Pretendard, Malgun Gothic, Segoe UI"
                   Margin="0,0,0,18"/>

        <!-- ── Claude ─────────────────────────────── -->
        <TextBlock Grid.Row="1" Text="Anthropic Claude" Style="{StaticResource SectionTitle}"/>

        <TextBlock Grid.Row="2" Style="{StaticResource DescText}">
            Required · <Hyperlink NavigateUri="https://console.anthropic.com/" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="console.anthropic.com" Foreground="#4EA8DE"/>
            </Hyperlink>
        </TextBlock>

        <PasswordBox x:Name="ApiKeyBox" Grid.Row="3"
                     Background="#2D2D30" Foreground="#E1E1E1" CaretBrush="#E1E1E1"
                     BorderBrush="#3E3E42" BorderThickness="1"
                     Padding="10,8" FontSize="13" Margin="0,0,0,8"
                     PasswordChanged="ClaudeKey_Changed"/>

        <ComboBox x:Name="ClaudeModelCombo" Grid.Row="4"
                  Style="{StaticResource DarkCombo}"
                  IsEnabled="False">
            <ComboBoxItem Tag="claude-sonnet-4-6"
                          Content="claude-sonnet-4-6  —  Best balance  ★ Recommended"
                          IsSelected="True"/>
            <ComboBoxItem Tag="claude-opus-4-6"
                          Content="claude-opus-4-6  —  Most capable"/>
            <ComboBoxItem Tag="claude-haiku-4-5"
                          Content="claude-haiku-4-5  —  Fastest &amp; cheapest"/>
        </ComboBox>

        <!-- Separator -->
        <Separator Grid.Row="5" Background="#3E3E42" Margin="0,16,0,16"/>

        <!-- ── Gemini ─────────────────────────────── -->
        <DockPanel Grid.Row="6" Margin="0,0,0,5">
            <TextBlock Text="Google Gemini" Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center"/>
            <TextBlock Text="Optional" Foreground="#5CAF5C" FontSize="11"
                       FontFamily="Pretendard, Malgun Gothic, Segoe UI"
                       Margin="8,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <TextBlock Grid.Row="7" Style="{StaticResource DescText}">
            Enables RAG (Revit API docs lookup) · <Hyperlink NavigateUri="https://aistudio.google.com/apikey" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="aistudio.google.com/apikey" Foreground="#4EA8DE"/>
            </Hyperlink>
        </TextBlock>

        <PasswordBox x:Name="GeminiApiKeyBox" Grid.Row="8"
                     Background="#2D2D30" Foreground="#E1E1E1" CaretBrush="#E1E1E1"
                     BorderBrush="#3E3E42" BorderThickness="1"
                     Padding="10,8" FontSize="13" Margin="0,0,0,8"
                     PasswordChanged="GeminiKey_Changed"/>

        <ComboBox x:Name="GeminiModelCombo" Grid.Row="9"
                  Style="{StaticResource DarkCombo}"
                  IsEnabled="False">
            <ComboBoxItem Tag="gemini-2.0-flash"
                          Content="gemini-2.0-flash  —  Fast &amp; cheap  ★ Recommended"
                          IsSelected="True"/>
            <ComboBoxItem Tag="gemini-2.5-pro"
                          Content="gemini-2.5-pro  —  Best RAG quality"/>
        </ComboBox>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Grid.Row="10" Foreground="#FF6B6B"
                   FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"
                   TextWrapping="Wrap" VerticalAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="32"
                    Margin="0,0,8,0" Click="CancelButton_Click"
                    Background="#3E3E42" Foreground="#E1E1E1" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="32"
                    Click="SaveButton_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
