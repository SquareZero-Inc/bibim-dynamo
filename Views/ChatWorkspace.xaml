<UserControl x:Class="BIBIM_MVP.ChatWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BIBIM_MVP"
             xmlns:loc="clr-namespace:BIBIM_MVP"
             mc:Ignorable="d"
             d:DesignHeight="780" d:DesignWidth="455">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/BIBIM_MVP;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <!-- Inverse Boolean Converter for IsEnabled binding -->
            <local:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            
            <!-- Color Palette -->
            <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="Surface" Color="#2D2D30"/>
            <SolidColorBrush x:Key="SurfaceLight" Color="#252526"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#007ACC"/>
            <SolidColorBrush x:Key="AccentGreen" Color="#4ADE80"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#E1E1E1"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
            <SolidColorBrush x:Key="TextMuted" Color="#888888"/>
            <SolidColorBrush x:Key="BorderSubtle" Color="#3E3E42"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== TOP NAVIGATION ==================== -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceLight}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/BIBIM_MVP;component/Assets/Icons/bibim-logo-white-24.png"
                           Width="24" Height="24" Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Nav_AppTitle}" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- New Chat Button -->
                <Button Grid.Column="1" 
                        Command="{Binding NewChatCommand}"
                        HorizontalAlignment="Left" Margin="16,0,0,0"
                        ToolTip="{loc:Loc Nav_NewChat}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="NewChatBtnBorder" Background="Transparent" 
                                    CornerRadius="8" Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Text="{loc:Loc Nav_NewChat}" FontSize="13" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="NewChatBtnBorder" Property="Background" Value="#3E3E42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 우측 정렬 그룹 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">

                    <!-- 앱 버전 배지 -->
                    <Border Background="#1E1E1E" CornerRadius="12" Padding="10,5"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="AppVersionText" Text="v—"
                                   Foreground="#666666" FontSize="11"
                                   FontFamily="Pretendard, Malgun Gothic, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </Border>

                </StackPanel>

                <!-- History Button -->
                <Button Grid.Column="3" Width="36" Height="36"
                        Command="{Binding ToggleHistoryPanelCommand}"
                        ToolTip="{loc:Loc Nav_History}" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HistoryBtnBorder" Background="Transparent" CornerRadius="8">
                                <TextBlock Text="☰" FontSize="18" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HistoryBtnBorder" Property="Background" Value="#3E3E42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings Button -->
                <Button Grid.Column="4" x:Name="SettingsButton" Width="36" Height="36"
                        Click="SettingsButton_Click" ToolTip="{loc:Loc Nav_Settings}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SettingsBtnBorder" Background="Transparent" CornerRadius="8">
                                <TextBlock Text="⚙" FontSize="18" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SettingsBtnBorder" Property="Background" Value="#3E3E42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SettingsMenu" HasDropShadow="True">
                            <ContextMenu.Template>
                                <ControlTemplate TargetType="{x:Type ContextMenu}">
                                    <Border Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6" Padding="4,6">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </ContextMenu.Template>
                            <ContextMenu.ItemContainerStyle>
                                <Style TargetType="{x:Type MenuItem}">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Foreground" Value="#E1E1E1"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type MenuItem}">
                                                <Border x:Name="MenuItemBorder" Background="Transparent" 
                                                        CornerRadius="4" Margin="2,1" Padding="16,10">
                                                    <TextBlock Text="{TemplateBinding Header}" 
                                                               Foreground="{TemplateBinding Foreground}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="MenuItemBorder" Property="Background" Value="#3E3E42"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ContextMenu.ItemContainerStyle>
                            <MenuItem Header="{loc:Loc Nav_ApiKeySettings}" Click="ApiKeySettings_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <!-- ==================== CHAT AREA (WebBrowser for Markdown) ==================== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Update Banner -->
            <Border Grid.Row="0"
                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}"
                    Padding="12,10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#007ACC"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMandatoryUpdate}" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding UpdateBannerText}"
                               Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Command="{Binding DownloadUpdateCommand}"
                            Cursor="Hand" Margin="8,0,4,0"
                            Background="White" Foreground="#007ACC"
                            BorderThickness="0" Padding="10,4"
                            FontSize="12" FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#007ACC"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{loc:Loc Update_BannerDownload}"/>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding DismissUpdateCommand}"
                            Cursor="Hand" Padding="6,4"
                            Background="Transparent" BorderThickness="0"
                            FontSize="12" Foreground="White"
                            Visibility="{Binding IsOptionalUpdate, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{loc:Loc Update_BannerDismiss}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Version Warning Banner (WPF overlay - always on top) -->
            <Border x:Name="VersionWarningBanner" Grid.Row="1"
                    Background="#FF9800" Visibility="Collapsed" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚠" FontSize="14" Foreground="#1a1a1a" 
                               VerticalAlignment="Top" Margin="0,2,8,0"/>
                    <TextBlock Grid.Column="1" x:Name="VersionWarningText" FontSize="12" Foreground="#1a1a1a" 
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WebBrowser x:Name="ChatBrowser" Grid.Row="0" 
                            Navigating="ChatBrowser_Navigating" 
                            Loaded="ChatBrowser_Loaded"
                            PreviewKeyDown="ChatBrowser_PreviewKeyDown"
                            KeyDown="ChatBrowser_KeyDown"
                            MouseRightButtonUp="ChatBrowser_RightClick"
                            Focusable="True">
                    <WebBrowser.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:Loc Chat_MenuCopy}" Click="CopyMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="{loc:Loc Chat_MenuSelectAll}" Click="SelectAllMenuItem_Click"/>
                        </ContextMenu>
                    </WebBrowser.ContextMenu>
                </WebBrowser>
                
                <!-- Retry Button (Task 7.1) -->
                <Border Grid.Row="1" 
                        Background="{StaticResource Surface}" 
                        Padding="16,12" 
                        Margin="16,8"
                        CornerRadius="8"
                        Visibility="{Binding IsRetryButtonVisible, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center">
                    <Button Command="{Binding RetryCommand}"
                            Cursor="Hand"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="RetryBtnBorder" 
                                        Background="#0078D4" 
                                        CornerRadius="8" 
                                        Padding="20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Loc Chat_Retry}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   Foreground="White" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="RetryBtnBorder" Property="Background" Value="#106EBE"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="RetryBtnBorder" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
            
            <!-- Fallback ScrollViewer for messages if WebBrowser fails -->
            <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto" 
                          Visibility="Collapsed"
                          Padding="0,8">
                <ItemsControl x:Name="MessagesItemsControl" ItemsSource="{Binding Messages}"/>
            </ScrollViewer>
        </Grid>

        <!-- ==================== LOADING/STATUS AREA ==================== -->
        <Border Grid.Row="2" Background="{StaticResource Surface}" 
                Padding="12,10" Margin="16,4" CornerRadius="16,16,16,4"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                <!-- Bouncing dots only - no text -->
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}" Margin="0,0,4,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="0" To="-6" Duration="0:0:0.3" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                    <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}" Margin="0,0,4,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.15">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="0" To="-6" Duration="0:0:0.3" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                    <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.3">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="0" To="-6" Duration="0:0:0.3" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                    <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                </Ellipse>
            </StackPanel>
        </Border>

        <!-- ==================== INPUT AREA ==================== -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceLight}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Analyze Button Row -->
                <Button Grid.Row="0" x:Name="AnalyzeButton"
                        Click="AnalyzeButton_Click"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12" Cursor="Hand"
                        ToolTip="{loc:Loc Chat_AnalyzeTooltip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="AnalyzeBtnBorder" Background="#19007ACC" 
                                    BorderBrush="{StaticResource AccentBlue}" BorderThickness="1"
                                    CornerRadius="20" Padding="16,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⌕" FontSize="18" Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Loc Chat_AnalyzeButton}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AnalyzeBtnBorder" Property="Background" Value="#33007ACC"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="AnalyzeBtnBorder" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Text Input Row -->
                <Border Grid.Row="1" Background="{StaticResource Surface}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputTextBox" Grid.Column="0" 
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent"
                                 Foreground="{StaticResource TextPrimary}"
                                 CaretBrush="{StaticResource TextPrimary}"
                                 BorderThickness="0" FontSize="14"
                                 VerticalContentAlignment="Center"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="36" MaxHeight="120"
                                 Margin="16,8,0,8"
                                 PreviewKeyDown="InputTextBox_PreviewKeyDown"/>

                        <!-- Send Button (visible when not busy) -->
                        <Button Grid.Column="1" Command="{Binding SendCommand}"
                                Width="36" Height="36" Margin="6" Cursor="Hand" ToolTip="{loc:Loc Chat_SendTooltip}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SendBtnBorder" Background="{StaticResource AccentBlue}" CornerRadius="8">
                                        <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" 
                                              Fill="White" Width="16" Height="16" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SendBtnBorder" Property="Background" Value="#0098FF"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="SendBtnBorder" Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Stop Button (visible when busy) -->
                        <Button Grid.Column="1" Command="{Binding CancelCommand}"
                                Width="36" Height="36" Margin="6" Cursor="Hand" ToolTip="{loc:Loc Chat_StopTooltip}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="StopBtnBorder" Background="#DC6B6B" CornerRadius="8">
                                        <Rectangle Fill="White" Width="12" Height="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="StopBtnBorder" Property="Background" Value="#E57373"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ==================== ANALYSIS PROGRESS MODAL ==================== -->
        <Grid Grid.RowSpan="4" x:Name="AnalysisModal" Visibility="Collapsed" Panel.ZIndex="200">
            <Border Background="#CC000000"/>
            <Border Background="{StaticResource Surface}"
                    Width="320" Height="260"
                    CornerRadius="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Loc Chat_AnalysisRunning}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Status text with pulsing indicator -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="AnalysisStatusText" 
                                   Text="{loc:Loc Chat_AnalysisExtracting}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14" HorizontalAlignment="Center"/>
                        <!-- Pulsing dots for "alive" indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Ellipse x:Name="PulseDot1" Width="10" Height="10" Fill="{StaticResource AccentBlue}" Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#007ACC" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="Scale1" CenterX="5" CenterY="5"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.4" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse x:Name="PulseDot2" Width="10" Height="10" Fill="{StaticResource AccentBlue}" Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#007ACC" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="Scale2" CenterX="5" CenterY="5"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.17">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.4" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse x:Name="PulseDot3" Width="10" Height="10" Fill="{StaticResource AccentBlue}">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#007ACC" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="Scale3" CenterX="5" CenterY="5"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.34">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.4" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 From="1" To="1.3" Duration="0:0:0.5" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar Grid.Row="2" x:Name="AnalysisProgressBar"
                                 Height="8" Margin="0,16,0,8"
                                 Background="#3E3E42" Foreground="{StaticResource AccentBlue}"
                                 Value="0" Maximum="100"/>

                    <TextBlock Grid.Row="3" x:Name="AnalysisProgressText"
                               Text="0%" FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"/>

                    <Button Grid.Row="4" x:Name="AnalysisCancelButton"
                            Click="AnalysisCancelButton_Click"
                            Margin="0,16,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CancelBtnBorder" Background="Transparent"
                                        BorderBrush="#3E3E42" BorderThickness="1"
                                        CornerRadius="8" Padding="20,8">
                                    <TextBlock Text="{loc:Loc Chat_CancelAnalysis}"
                                               FontSize="13" Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CancelBtnBorder" Property="BorderBrush" Value="#FF6B6B"/>
                                        <Setter TargetName="CancelBtnBorder" Property="Background" Value="#1AFF6B6B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== HISTORY PANEL OVERLAY ==================== -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="100"
              Visibility="{Binding IsHistoryPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#99000000" MouseDown="HistoryOverlay_MouseDown"/>
            <Border Background="{StaticResource SurfaceLight}" 
                    HorizontalAlignment="Right" Width="380"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Surface}" 
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Loc Chat_HistoryTitle}" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Width="32" Height="32"
                                    Command="{Binding ToggleHistoryPanelCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBtnBorder" Background="Transparent" CornerRadius="4">
                                            <TextBlock Text="✕" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBtnBorder" Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                        <ItemsControl ItemsSource="{Binding HistoryList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.LoadHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Margin="0,0,0,8" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ItemBorder" Background="#2D2D30" 
                                                        BorderBrush="#3E3E42" BorderThickness="1"
                                                        CornerRadius="8" Padding="16">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <TextBlock Text="{Binding Timestamp}" FontSize="12"
                                                                       Foreground="#888888" HorizontalAlignment="Left"/>
                                                            <TextBlock Text="{Binding VersionTag}" FontSize="11"
                                                                       Foreground="#007ACC" HorizontalAlignment="Right"
                                                                       FontWeight="SemiBold"/>
                                                        </Grid>
                                                        <TextBlock Grid.Row="1" Text="{Binding DisplayTitle}" FontSize="14" 
                                                                   FontWeight="SemiBold" Margin="0,8,0,0"
                                                                   Foreground="#E1E1E1" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#007ACC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
